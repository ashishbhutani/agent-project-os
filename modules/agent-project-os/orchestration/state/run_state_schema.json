{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Agent Project OS Runtime State",
  "type": "object",
  "required": ["role", "id", "status", "updated_at_utc"],
  "properties": {
    "role": {"type": "string", "enum": ["worker", "mayor"]},
    "id": {"type": "string"},
    "pid": {"type": "integer"},
    "host": {"type": "string"},
    "status": {"type": "string"},
    "current_ticket": {"type": "string"},
    "last_ticket": {"type": "string"},
    "last_error": {"type": "string"},
    "updated_at_utc": {"type": "string", "format": "date-time"}
  },
  "additionalProperties": true
}
